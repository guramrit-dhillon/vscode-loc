{
  "name": "vscode-loc-hindi",
  "displayName": "Hindi Language Pack for VS Code",
  "description": "Language Pack for Hindi (हिन्दी) - provides localized UI for VS Code",
  "version": "0.1.1",
  "publisher": "gdhillon",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Language Packs"
  ],
  "keywords": [
    "language pack",
    "hindi",
    "हिन्दी",
    "localization",
    "l10n",
    "i18n",
    "translation",
    "indian languages",
    "south asian languages"
  ],
  "galleryBanner": {
    "color": "#0066CC",
    "theme": "dark"
  },
  "qna": "https://github.com/guramrit-dhillon/vscode-loc/discussions",
  "bugs": {
    "url": "https://github.com/guramrit-dhillon/vscode-loc/issues"
  },
  "homepage": "https://github.com/guramrit-dhillon/vscode-loc#readme",
  "contributes": {
    "localizations": [
      {
        "languageId": "hi",
        "languageName": "Hindi",
        "localizedLanguageName": "हिन्दी",
        "translations": [
          {
            "id": "vscode",
            "path": "./translations/main.i18n.json"
          }
        ]
      }
    ]
  },
  "scripts": {
    "build": "node build.mjs",
    "watch": "node build.mjs --watch",
    "clean": "rimraf dist out *.vsix",
    "package": "npm run build && vsce package",
    "vscode:prepublish": "npm run build"
  },
  "devDependencies": {
    "@vscode/vsce": "^2.22.0",
    "ovsx": "^0.9.0",
    "rimraf": "^5.0.5"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/guramrit-dhillon/vscode-loc"
  }
}
