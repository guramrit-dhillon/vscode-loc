{
  "name": "@vscode-loc/indian-languages",
  "version": "0.1.0",
  "description": "VSCode language extensions for Indian languages (Punjabi, Hindi)",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:punjabi": "npm run build -w vscode-loc-punjabi",
    "build:hindi": "npm run build -w vscode-loc-hindi",
    "watch": "npm run watch --workspaces --if-present",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "clean": "npm run clean --workspaces --if-present",
    "typecheck": "tsc --noEmit",
    "package": "npm run package --workspaces --if-present",
    "vscode:prepublish": "npm run build",
    "translations:build": "node scripts/build-translations.mjs",
    "translations:validate": "node scripts/build-translations.mjs --validate",
    "translations:merge": "node scripts/merge-translations.mjs",
    "translations:ai": "node scripts/translate-ai.mjs",
    "translations:batch": "node scripts/translate-batch.mjs",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "node scripts/release.mjs"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "esbuild": "^0.19.11",
    "eslint": "^8.56.0",
    "sharp": "^0.34.5",
    "typescript": "^5.3.3",
    "xlsx": "^0.18.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "keywords": [
    "vscode",
    "extension",
    "localization",
    "l10n",
    "punjabi",
    "hindi",
    "indian-languages",
    "monorepo"
  ],
  "author": "guramrit-dhillon",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.79.0"
  }
}
